<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════
   THEME VARIABLES
═══════════════════════════════════════ */
[data-theme="dark"]{
  --bg:#001833;--bg2:#0A1E3A;--bg3:#0D2548;--bg4:#1A3A60;
  --primary:#0055CC;--primary2:#0044AA;--primary-soft:rgba(0,85,204,.15);
  --accent:#FDB913;--accent2:#e6a800;--accent-soft:rgba(253,185,19,.14);
  --green:#00C878;--green2:#009E5E;--green-soft:rgba(0,200,120,.12);
  --red:#FF4F6E;--orange:#FF8C42;--cyan:#00D4FF;--purple:#9B6BFF;
  --text:#F0F6FF;--text2:#8AABCC;--text3:#4A6A88;
  --card:#0D2040;--border:#1C3D65;--border2:#0F2A4A;
  --shadow:rgba(0,0,0,.4);
}
[data-theme="light"]{
  --bg:#EEF4FF;--bg2:#FFFFFF;--bg3:#F5F9FF;--bg4:#DCE8FF;
  --primary:#003399;--primary2:#002277;--primary-soft:rgba(0,51,153,.1);
  --accent:#FDB913;--accent2:#E8A800;--accent-soft:rgba(253,185,19,.15);
  --green:#007A3D;--green2:#00612F;--green-soft:rgba(0,122,61,.1);
  --red:#C62828;--orange:#E65100;--cyan:#0077B6;--purple:#5C35B8;
  --text:#1A2B4A;--text2:#4A6080;--text3:#7A90A8;
  --card:#FFFFFF;--border:#C8D8F0;--border2:#E0EAF8;
  --shadow:rgba(0,51,153,.12);
}

/* ═══════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{
  background:var(--bg);color:var(--text);
  font-family:'Inter',system-ui,sans-serif;
  font-size:15px;line-height:1.55;min-height:100vh;
  padding-bottom:80px;
}
a{color:var(--accent);text-decoration:none}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--primary);border-radius:2px}

/* ═══════════════════════════════════════
   TOPBAR
═══════════════════════════════════════ */
.topbar{
  background:var(--primary2);
  border-bottom:3px solid var(--accent);
  padding:12px 16px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:300;gap:10px;
}
[data-theme="light"] .topbar{background:var(--primary)}
.topbar-brand{display:flex;align-items:center;gap:10px;min-width:0}
.logo-circle{
  width:40px;height:40px;min-width:40px;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:900;color:var(--primary);
  box-shadow:0 3px 10px rgba(253,185,19,.4);
}
.brand-name{font-size:14px;font-weight:700;color:#FFF;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.brand-sub{font-size:9.5px;color:var(--accent);letter-spacing:.09em;text-transform:uppercase;font-weight:600}
.topbar-right{display:flex;align-items:center;gap:7px;flex-shrink:0}
.theme-toggle{
  background:var(--primary-soft);border:1.5px solid var(--border);
  border-radius:20px;padding:5px 11px;font-size:12px;font-weight:600;
  color:var(--text);cursor:pointer;white-space:nowrap;transition:all .2s;
}
.theme-toggle:hover{border-color:var(--accent);color:var(--accent)}
.btn{
  display:inline-flex;align-items:center;gap:5px;
  padding:8px 14px;border-radius:8px;font-size:12px;font-weight:700;
  cursor:pointer;border:none;transition:all .2s;text-decoration:none;
  font-family:'Inter',sans-serif;white-space:nowrap;
}
.btn-accent{background:linear-gradient(135deg,var(--accent),var(--accent2));color:var(--primary);font-weight:800}
.btn-accent:active{opacity:.85;transform:scale(.97)}
.btn-outline{background:transparent;border:1.5px solid rgba(255,255,255,.3);color:#fff}
[data-theme="light"] .btn-outline{border-color:var(--border);color:var(--text)}

/* ═══════════════════════════════════════
   HERO & CAPITAL WIDGET
═══════════════════════════════════════ */
.hero{
  background:linear-gradient(160deg,var(--bg2) 0%,var(--bg) 100%);
  border-bottom:1px solid var(--border);
  padding:20px 16px 18px;
}
[data-theme="light"] .hero{background:linear-gradient(160deg,var(--primary) 0%,var(--primary2) 100%)}
.hero-greeting{font-size:20px;font-weight:800;color:var(--text);margin-bottom:3px}
[data-theme="light"] .hero-greeting{color:#FFF}
.hero-sub{font-size:13px;color:var(--text2);margin-bottom:16px}
[data-theme="light"] .hero-sub{color:rgba(255,255,255,.8)}
.hero-sub span{color:var(--accent);font-weight:600}

/* Capital widget */
.capital-widget{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:14px;padding:16px;
  box-shadow:0 4px 20px var(--shadow);
}
[data-theme="light"] .capital-widget{box-shadow:0 4px 20px var(--shadow);border-color:rgba(255,255,255,.5);background:rgba(255,255,255,.95)}
.cw-label{font-size:11px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px}
[data-theme="light"] .cw-label{color:var(--primary)}

/* +/- controls for mobile */
.cap-ctrl{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.cap-btn{
  width:42px;height:42px;border-radius:10px;
  background:var(--primary-soft);border:1.5px solid var(--border);
  color:var(--text);font-size:22px;font-weight:300;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:all .15s;flex-shrink:0;user-select:none;-webkit-user-select:none;
}
.cap-btn:active{background:var(--accent-soft);border-color:var(--accent);color:var(--accent);transform:scale(.94)}
.cap-display{
  flex:1;text-align:center;
  font-size:28px;font-weight:800;color:var(--accent);
  line-height:1;letter-spacing:-1px;
}
.cap-display span{font-size:14px;color:var(--text2);font-weight:500;margin-right:3px}
.cap-slider{
  width:100%;-webkit-appearance:none;appearance:none;
  height:5px;border-radius:3px;
  background:linear-gradient(to right,var(--accent) 0%,var(--accent) var(--pct,5%),var(--border) var(--pct,5%));
  outline:none;cursor:pointer;margin:6px 0 10px;
}
.cap-slider::-webkit-slider-thumb{
  -webkit-appearance:none;appearance:none;
  width:22px;height:22px;border-radius:50%;
  background:var(--accent);border:2px solid var(--bg);
  cursor:pointer;box-shadow:0 2px 8px rgba(253,185,19,.5);
}
.cap-slider::-moz-range-thumb{
  width:22px;height:22px;border-radius:50%;
  background:var(--accent);border:2px solid var(--bg);cursor:pointer;
}
.presets{display:flex;gap:6px;flex-wrap:wrap}
.preset{
  padding:5px 10px;border-radius:7px;
  border:1.5px solid var(--border);background:transparent;
  color:var(--text2);font-size:11px;font-weight:600;cursor:pointer;
  transition:all .15s;font-family:'Inter',sans-serif;
}
.preset:active,.preset.on{background:var(--accent-soft);border-color:var(--accent);color:var(--accent)}

/* ═══════════════════════════════════════
   NAV TABS
═══════════════════════════════════════ */
.nav-tabs{
  display:flex;background:var(--bg2);border-bottom:1px solid var(--border);
  position:sticky;top:65px;z-index:200;overflow-x:auto;scrollbar-width:none;
}
.nav-tabs::-webkit-scrollbar{display:none}
[data-theme="light"] .nav-tabs{background:var(--bg3)}
.nav-tab{
  padding:12px 16px;font-size:13px;font-weight:600;
  color:var(--text2);cursor:pointer;border-bottom:2.5px solid transparent;
  white-space:nowrap;transition:all .2s;flex-shrink:0;
}
.nav-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.nav-tab:hover{color:var(--text)}

/* ═══════════════════════════════════════
   MAIN
═══════════════════════════════════════ */
.main{max-width:1100px;margin:0 auto;padding:20px 14px 20px}
.tab-content{display:none}.tab-content.active{display:block}
.sec-title{font-size:18px;font-weight:800;color:var(--text);margin-bottom:3px}
.sec-sub{font-size:13px;color:var(--text2);margin-bottom:16px;line-height:1.5}
.sec-sub b{color:var(--accent)}

/* ═══════════════════════════════════════
   PRODUCT GRID
═══════════════════════════════════════ */
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:14px;margin-bottom:20px}
.prod-card{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:14px;overflow:hidden;
  transition:transform .2s,box-shadow .2s,border-color .2s;
}
.prod-card:hover{transform:translateY(-2px);box-shadow:0 10px 36px var(--shadow)}
.prod-card.featured{border-color:var(--accent);box-shadow:0 0 0 1px var(--accent-soft)}
.prod-card.pe-card{border-color:var(--orange);box-shadow:0 0 0 1px rgba(255,140,66,.2)}
[data-theme="light"] .prod-card{box-shadow:0 2px 12px var(--shadow)}

.prod-head{
  background:linear-gradient(135deg,var(--bg3),var(--bg2));
  padding:15px 15px 12px;border-bottom:1px solid var(--border);position:relative;
}
[data-theme="light"] .prod-head{background:linear-gradient(135deg,var(--bg4),var(--bg3))}
.prod-card.featured .prod-head{background:linear-gradient(135deg,rgba(0,85,204,.2),var(--bg2))}
.prod-card.pe-card .prod-head{background:linear-gradient(135deg,rgba(255,140,66,.15),var(--bg2))}
[data-theme="light"] .prod-card.pe-card .prod-head{background:linear-gradient(135deg,rgba(255,140,66,.12),var(--bg3))}

.ribbon{
  position:absolute;top:0;right:0;
  background:linear-gradient(135deg,var(--accent),var(--accent2));
  color:var(--primary);font-size:9px;font-weight:800;
  padding:4px 10px;border-radius:0 13px 0 8px;letter-spacing:.05em;
}
.pe-ribbon{background:linear-gradient(135deg,var(--orange),#cc6600)}
.prod-icon{
  width:42px;height:42px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:19px;flex-shrink:0;margin-bottom:9px;
}
.pi-blue{background:rgba(0,85,204,.18)}
.pi-green{background:var(--green-soft)}
.pi-gold{background:var(--accent-soft)}
.pi-orange{background:rgba(255,140,66,.18)}
.pi-purple{background:rgba(155,107,255,.18)}
.pi-cyan{background:rgba(0,212,255,.15)}

.prod-badges{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px}
.badge{padding:3px 8px;border-radius:5px;font-size:10px;font-weight:700;letter-spacing:.03em}
.b-prot{background:var(--green-soft);color:var(--green)}
.b-tax{background:var(--accent-soft);color:var(--accent2)}
.b-liq{background:rgba(0,212,255,.15);color:var(--cyan)}
.b-new{background:linear-gradient(135deg,var(--accent),var(--accent2));color:var(--primary)}
.b-hot{background:linear-gradient(135deg,var(--orange),#cc6600);color:#fff}
[data-theme="light"] .b-prot{color:var(--green2)} [data-theme="light"] .b-tax{color:#8a6200}
[data-theme="light"] .b-liq{color:var(--cyan)}

.prod-name{font-size:14px;font-weight:800;color:var(--text);line-height:1.3;margin-bottom:3px}
.prod-meta{font-size:10px;color:var(--text3);font-family:monospace}
.prod-body{padding:14px 15px}

/* ═══════════════════════════════════════
   COUPON PILLS
═══════════════════════════════════════ */
.cpills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px}
.cpill{
  flex:1;min-width:60px;text-align:center;
  background:var(--bg3);border:1px solid var(--border);
  border-radius:9px;padding:8px 6px;
}
.cpill .pct{font-size:20px;font-weight:800;color:var(--green);line-height:1}
.cpill .lbl{font-size:9px;color:var(--text2);margin-top:2px;line-height:1.3}
.cpill.prot{background:var(--green-soft);border-color:rgba(0,200,120,.3)}
.cpill.prot .pct{color:var(--green)}

/* ═══════════════════════════════════════
   FEATURE LIST
═══════════════════════════════════════ */
.flist{list-style:none;margin-bottom:10px}
.flist li{
  display:flex;align-items:flex-start;gap:8px;
  padding:5px 0;border-bottom:1px solid var(--border2);
  font-size:12.5px;color:var(--text2);line-height:1.45;
}
.flist li:last-child{border-bottom:none}
.flist li .ic{font-size:14px;flex-shrink:0;margin-top:1px}
.flist li b{color:var(--text)}

/* ═══════════════════════════════════════
   MINI CALC
═══════════════════════════════════════ */
.mcalc{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:10px;padding:11px 13px;margin-top:10px;
}
.cr{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-size:12px}
.cr .cl{color:var(--text2)}
.cr .cv{font-weight:700;color:var(--text)}
.cr .cv.g{color:var(--green)}
.cr .cv.a{color:var(--accent)}
.cr .cv.o{color:var(--orange)}
.cdiv{border:none;border-top:1px solid var(--border);margin:5px 0}

/* ═══════════════════════════════════════
   HIGHLIGHT BOX
═══════════════════════════════════════ */
.hbox{
  display:flex;align-items:flex-start;gap:9px;
  border-radius:9px;padding:10px 12px;margin-top:9px;
  font-size:12px;line-height:1.45;
}
.hbox.green{background:var(--green-soft);border:1px solid rgba(0,200,120,.25)}
.hbox.gold{background:var(--accent-soft);border:1px solid rgba(253,185,19,.3)}
.hbox.blue{background:var(--primary-soft);border:1px solid rgba(0,85,204,.3)}
.hbox.orange{background:rgba(255,140,66,.1);border:1px solid rgba(255,140,66,.35)}
[data-theme="light"] .hbox.green{background:rgba(0,122,61,.08);border-color:rgba(0,122,61,.25)}
[data-theme="light"] .hbox.gold{background:rgba(253,185,19,.1);border-color:rgba(253,185,19,.35)}
.hbox .hi{font-size:18px;flex-shrink:0}
.hbox .ht{color:var(--text2)}
.hbox .ht b{color:var(--text)}
.hbox .ht strong{color:var(--green)}
[data-theme="light"] .hbox .ht strong{color:var(--green2)}

/* ═══════════════════════════════════════
   PROGRESS BARS
═══════════════════════════════════════ */
.pbar-wrap{margin:6px 0}
.pbar-lbl{display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px}
.pbar-lbl .nm{color:var(--text2)}.pbar-lbl .vl{color:var(--text);font-weight:600}
.pbar{height:5px;background:var(--bg4);border-radius:3px;overflow:hidden}
.pbf{height:100%;border-radius:3px;transition:width .8s ease}
.pbf.g{background:linear-gradient(90deg,var(--green2),var(--green))}
.pbf.b{background:linear-gradient(90deg,var(--primary2),var(--primary))}
.pbf.a{background:linear-gradient(90deg,var(--accent2),var(--accent))}

/* ═══════════════════════════════════════
   RISK METER
═══════════════════════════════════════ */
.risk-row{display:flex;align-items:center;gap:6px;margin-top:10px}
.risk-lbl{font-size:11px;color:var(--text2);flex-shrink:0}
.risk-blocks{display:flex;gap:2px;flex:1}
.rb{height:5px;border-radius:2px;flex:1}
.rb.on{background:var(--green)}.rb.mid{background:var(--accent)}.rb.off{background:var(--bg4)}
.risk-txt{font-size:10px;color:var(--text2);margin-left:4px;white-space:nowrap}

/* ═══════════════════════════════════════
   EXPAND
═══════════════════════════════════════ */
.exp-btn{
  width:100%;background:transparent;border:none;
  border-top:1px solid var(--border);color:var(--text2);
  font-size:12px;padding:9px;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:5px;
  transition:color .2s;font-family:'Inter',sans-serif;
}
.exp-btn:hover{color:var(--accent)}
.exp-body{display:none;padding:12px 15px;border-top:1px solid var(--border)}
.exp-body.open{display:block}

/* ═══════════════════════════════════════
   CHART
═══════════════════════════════════════ */
.chart-wrap{position:relative;height:150px;margin-top:10px}

/* ═══════════════════════════════════════
   PRIVATE EQUITY SPECIAL SECTION
═══════════════════════════════════════ */
.pe-hero{
  background:linear-gradient(135deg,rgba(255,140,66,.08) 0%,rgba(155,107,255,.06) 100%);
  border:2px solid rgba(255,140,66,.4);
  border-radius:14px;padding:18px;margin-bottom:12px;
}
.pe-hero-title{font-size:16px;font-weight:800;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:8px}
.pe-hero-sub{font-size:12.5px;color:var(--text2);margin-bottom:14px;line-height:1.5}
.pe-hero-sub b{color:var(--orange)}
.ipo-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px;margin-bottom:12px}
.ipo-card{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:10px;padding:10px;text-align:center;
}
.ipo-card .ic-name{font-size:12px;font-weight:700;color:var(--text);margin-bottom:3px}
.ipo-card .ic-sub{font-size:10px;color:var(--text2);line-height:1.3}
.ipo-card .ic-val{font-size:13px;font-weight:800;color:var(--green);margin-top:5px}
.ipo-card .ic-status{
  display:inline-block;font-size:9px;font-weight:700;
  padding:2px 6px;border-radius:4px;margin-top:4px;
}
.status-hot{background:rgba(255,140,66,.2);color:var(--orange)}
.status-in{background:var(--green-soft);color:var(--green)}
[data-theme="light"] .status-in{color:var(--green2)}

.return-viz{
  background:var(--bg2);border:1px solid var(--border);
  border-radius:12px;padding:14px;margin-bottom:12px;
}
.rv-title{font-size:12px;font-weight:600;color:var(--text2);margin-bottom:12px;text-transform:uppercase;letter-spacing:.07em}
.rv-bar{position:relative;height:36px;background:var(--bg4);border-radius:8px;overflow:hidden;margin-bottom:8px}
.rv-fill{
  height:100%;display:flex;align-items:center;padding-left:10px;
  font-size:12px;font-weight:700;color:var(--primary);
  background:linear-gradient(90deg,var(--accent),#ffcc44);
  border-radius:8px;transition:width 1s ease;
}
.rv-markers{display:flex;justify-content:space-between;font-size:10px;color:var(--text3)}
.rv-big{text-align:center;margin-top:8px}
.rv-big .mul{font-size:36px;font-weight:900;color:var(--orange);letter-spacing:-1px}
.rv-big .sub{font-size:12px;color:var(--text2);margin-top:2px}

/* ═══════════════════════════════════════
   CREDIT LOMBARD
═══════════════════════════════════════ */
.lombard-section{
  background:var(--card);border:1.5px solid var(--border);
  border-radius:14px;padding:20px;margin-bottom:20px;
}
.lb-header{
  background:linear-gradient(135deg,var(--green-soft),var(--primary-soft));
  border:1.5px solid rgba(0,200,120,.3);
  border-radius:12px;padding:16px;margin-bottom:18px;
}
[data-theme="light"] .lb-header{background:linear-gradient(135deg,rgba(0,122,61,.06),rgba(0,51,153,.06))}
.lb-title{font-size:18px;font-weight:800;color:var(--text);margin-bottom:4px;display:flex;align-items:center;gap:10px}
.lb-sub{font-size:13px;color:var(--text2);line-height:1.5}
.lb-sub b{color:var(--green)}
[data-theme="light"] .lb-sub b{color:var(--green2)}
.lb-benefits{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin:14px 0}
.lbb{
  background:var(--bg3);border:1px solid var(--border);
  border-radius:9px;padding:10px;text-align:center;
}
