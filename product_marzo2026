// ════════════════════════════════════════════
//  PAC SIMULATOR (8.3% net annual — engine only)
// ════════════════════════════════════════════
function calcPAC(){
  const pm = parseFloat(document.getElementById('pacMensile')?.value)||500;
  const ay = parseFloat(document.getElementById('pacAnni')?.value)||20;
  const r = 0.083/12; // net annual rate / 12
  const n = ay * 12;
  const fv = pm * (Math.pow(1+r, n) - 1) / r;
  const versato = pm * n;
  const guadagno = fv - versato;
  const s = (id,v)=>{const el=document.getElementById(id);if(el)el.textContent=v};
  s('pacVersato', fmt(versato));
  s('pacCapitale', fmt(fv));
  s('pacGuadagno', '+'+fmt(guadagno));
}

// ════════════════════════════════════════════
//  LOMBARD CALC
// ════════════════════════════════════════════
function syncLcP(v){ document.getElementById('lcPS').value=Math.min(v,3000000); calcLombard(); }
function syncLcPS(v){ document.getElementById('lcP').value=Math.round(v); calcLombard(); }
function syncLcU(v){ document.getElementById('lcUS').value=Math.min(v,2400000); calcLombard(); }
function syncLcUS(v){ document.getElementById('lcU').value=Math.round(v); calcLombard(); }

function calcLombard(){
  const P = parseFloat(document.getElementById('lcP')?.value)||100000;
  const E = parseFloat(document.getElementById('lcE')?.value)||1.86;
  const U = parseFloat(document.getElementById('lcU')?.value)||50000;
  const M = parseInt(document.getElementById('lcM')?.value)||12;
  const rate = (E+0.10)/100;
  const fido = P*.80;
  const uso = Math.min(U,fido);
  const intA = uso*rate;
  const intM = intA/12;
  const intT = intA*(M/12);
  const cedPortf = P*.05;
  const bilancio = cedPortf - intA;
  const cedLomb = uso*.05;
  const netto = cedLomb - intA;

  set('lrF',fmt(fido)); set('lrT',fmtPct(E+0.10));
  set('lrIM',fmt(intM)); set('lrIT',fmt(intT));
  const subEl=document.getElementById('lrISub'); if(subEl) subEl.textContent=M+' mesi';
  set('lrC',fmt(cedPortf));
  const bEl=document.getElementById('lrB');
  if(bEl){ bEl.textContent=(bilancio>=0?'+':'')+fmt(bilancio); bEl.className='lv '+(bilancio>=0?'g':'r'); }
  set('lsU',fmt(uso)); set('lsC',fmt(cedLomb)); set('lsCo',fmt(intA));
  const vEl=document.getElementById('lsV');
  const vtEl=document.getElementById('lsVT');
  if(netto>0){
    if(vEl){vEl.style.background='var(--green-soft)';vEl.style.borderColor='rgba(0,200,120,.3)'}
    document.querySelector('.ls-verdict .vi').textContent='✅';
    if(vtEl) vtEl.innerHTML=`<b>Strategia Positiva!</b> Cedola SD 5% &gt; Tasso Lombard ${fmtPct(E+0.10)}. Guadagno netto: <strong>+${fmt(netto)}/anno</strong> senza nuovo capitale.`;
  } else {
    if(vEl){vEl.style.background='rgba(255,79,110,.08)';vEl.style.borderColor='rgba(255,79,110,.3)'}
    document.querySelector('.ls-verdict .vi').textContent='⚠️';
    if(vtEl) vtEl.innerHTML=`<b>Attenzione:</b> Tasso Lombard (${fmtPct(E+0.10)}) > Cedola SD (5%). Strategia non conveniente. Attendere ribasso Euribor o usare Lombard per altri scopi.`;
  }
  const dsEl=document.getElementById('lsDesc');
  if(dsEl) dsEl.textContent=`Portafoglio ${fmt(P)} → fido max ${fmt(fido)} (80% LTV) al ${fmtPct(E+0.10)}. Investendo ${fmt(uso)} in SD 7Y la cedola è ${fmt(cedLomb)} vs costo ${fmt(intA)}.`;
}

// ════════════════════════════════════════════
//  CHARTS
// ════════════════════════════════════════════
let etfChart=null, allocChart=null;
const ALLOC_COLORS=['#00C878','#0055CC','#FDB913','#00D4FF','#9B6BFF','#FF8C42'];

function initETFChart(){
  const ctx=document.getElementById('chartETF');
  if(!ctx||etfChart) return;
  const isDark=document.documentElement.getAttribute('data-theme')==='dark';
  const gc=isDark?'#1A3A60':'#C8D8F0';
  const tc=isDark?'#4A6A88':'#7A90A8';
  etfChart=new Chart(ctx,{type:'line',data:{
    labels:['2020','2021','2022','2023','2024','2025'],
    datasets:[
      {label:'Dinamico',data:[100,118,108,126,141,162],borderColor:'#00C878',backgroundColor:'rgba(0,200,120,.08)',fill:true,tension:.4,pointRadius:3},
      {label:'Bilanciato',data:[100,112,106,118,129,144],borderColor:'#0055CC',backgroundColor:'rgba(0,85,204,.06)',fill:true,tension:.4,pointRadius:3},
      {label:'Prudente',data:[100,106,103,109,115,122],borderColor:'#FDB913',backgroundColor:'rgba(253,185,19,.06)',fill:true,tension:.4,pointRadius:3},
    ]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{labels:{color:tc,font:{size:10}}}},
    scales:{x:{ticks:{color:tc,font:{size:9}},grid:{color:gc}},y:{ticks:{color:tc,font:{size:9}},grid:{color:gc}}}
  }});
}

function initAllocChart(){
  const ctx=document.getElementById('chartAlloc');
  if(!ctx) return;
  if(allocChart){allocChart.destroy();allocChart=null;}
  allocChart=new Chart(ctx,{type:'doughnut',data:{
    labels:['SD 7Y','SD 3Y','Certificati','Active ETF','Longevity','ELTIF PE'],
    datasets:[{data:[35,20,15,15,10,5],backgroundColor:ALLOC_COLORS,borderWidth:2,borderColor:'var(--card)',hoverOffset:5}]
  },options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false},tooltip:{callbacks:{label:c=>`${c.label}: ${c.parsed}%`}}},
    cutout:'62%'
  }});
}

// ════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════
document.addEventListener('DOMContentLoaded',()=>{
  updateAllCalcs();
  setTimeout(initETFChart,500);
  // Touch-friendly slider
  const sl=document.getElementById('capSlider');
  if(sl){
    sl.addEventListener('touchstart',e=>e.stopPropagation(),{passive:true});
    sl.addEventListener('touchmove',e=>{updateCap(sl.value);e.stopPropagation();},{passive:true});
  }
});
</script>
