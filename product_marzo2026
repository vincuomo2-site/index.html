<script>

// ════════════════════════════════════════════
//  SHARE / PASSA PAROLA
// ════════════════════════════════════════════
const SHARE_MSG = `🛡 Ciao! Ho trovato questa simulazione di investimento con Vincenzo Cuomo, Private Banker FinecoBank.

Puoi inserire il tuo capitale e vedere subito i rendimenti di ogni prodotto, il Fido Agevolato (liquidità extra senza vendere nulla) e il portafoglio consigliato.

📊 Simula gratuitamente: ${window.location.href}

📞 Per info: +39 335 6032819`;

function shareApp(){
  if(navigator.share){
    navigator.share({
      title:'Le Tue Opportunità · FinecoBank Private Banking',
      text:'Simula i tuoi investimenti con Vincenzo Cuomo, Private Banker FinecoBank. Protezione capitale, cedole agevolate e molto altro.',
      url: window.location.href
    }).catch(()=>{});
  } else {
    shareWA();
  }
}

function shareWA(){
  const url = 'https://wa.me/?text='+encodeURIComponent(SHARE_MSG);
  window.open(url,'_blank','noopener');
}

function shareEmail(){
  const sub = encodeURIComponent('💰 Simulatore Investimenti FinecoBank - ti può interessare');
  const body = encodeURIComponent(SHARE_MSG);
  window.open(`mailto:?subject=${sub}&body=${body}`);
}

function copyLink(){
  const text = SHARE_MSG;
  if(navigator.clipboard){
    navigator.clipboard.writeText(text).then(()=>showToast('✅ Messaggio copiato!'));
  } else {
    const ta = document.createElement('textarea');
    ta.value = text; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('✅ Messaggio copiato!');
  }
}

function showToast(msg){
  const t = document.getElementById('shareToast');
  if(!t) return;
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2500);
}

// ════════════════════════════════════════════
//  THEME
// ════════════════════════════════════════════
function toggleTheme(){
  const h = document.documentElement;
  const isDark = h.getAttribute('data-theme')==='dark';
  h.setAttribute('data-theme', isDark?'light':'dark');
  const btn = document.getElementById('themeBtn');
  btn.textContent = isDark ? '🌙 Scuro' : '☀️ Chiaro';
  btn.style.background = isDark ? '' : 'var(--accent)';
  btn.style.color = isDark ? '' : 'var(--primary)';
  if(allocChart){ allocChart.destroy(); allocChart=null; }
  if(document.getElementById('tab-portafoglio').classList.contains('active')) initAllocChart();
}

// ════════════════════════════════════════════
//  CAPITAL CONTROLS
// ════════════════════════════════════════════
let globalCap = 100000;
let adjTimer = null;
let adjDir = 0;

function getStep(v){
  if(v < 10000) return 500;
  if(v < 50000) return 1000;
  if(v < 200000) return 5000;
  if(v < 1000000) return 10000;
  return 50000;
}

function startAdj(dir){
  adjDir = dir;
  doAdj();
  adjTimer = setInterval(()=>{ doAdj(); }, 180);
}
function stopAdj(){
  clearInterval(adjTimer);
  adjTimer = null;
}
function doAdj(){
  const step = getStep(globalCap);
  let v = globalCap + adjDir * step;
  v = Math.max(1000, Math.min(3000000, Math.round(v/step)*step));
  setCap(v);
}

function updateCap(v){
  v = parseFloat(v);
  if(isNaN(v)||v<1000) v=1000;
  if(v>3000000) v=3000000;
  globalCap = v;
  document.getElementById('capVal').textContent = Math.round(v).toLocaleString('it-IT');
  const pct = ((v-1000)/(3000000-1000))*100;
  document.getElementById('capSlider').style.setProperty('--pct', pct+'%');
  document.querySelectorAll('.preset').forEach(b=>b.classList.remove('on'));
  updateAllCalcs();
}

function setCap(v){
  globalCap = v;
  document.getElementById('capSlider').value = v;
  document.getElementById('capVal').textContent = Math.round(v).toLocaleString('it-IT');
  const pct = ((v-1000)/(3000000-1000))*100;
  document.getElementById('capSlider').style.setProperty('--pct', pct+'%');
  document.querySelectorAll('.preset').forEach(b=>{
    const bv = parseFloat(b.onclick.toString().match(/\d+/)?.[0]||0);
    b.classList.toggle('on', bv===v);
  });
  updateAllCalcs();
}

function fmt(n){
  if(n===0) return '€0';
  if(n>=1000000) return '€'+(n/1000000).toFixed(2).replace('.',',')+'M';
  return '€'+Math.round(n).toLocaleString('it-IT');
}
function fmtPct(n){return n.toFixed(2).replace('.',',')+'%'}

function updateAllCalcs(){
  const c = globalCap;
  // 7Y
  set('inv7y',fmt(c)); set('c7y1',fmt(c*.05)+'/anno'); set('c7y1net',fmt(c*.05*.855)+'/anno');
  set('c7y2',fmt(c*.03)+'/anno'); set('c7y2net',fmt(c*.03*.855)+'/anno'); set('cap7y',fmt(c));
  // 3Y
  set('inv3y',fmt(c)); set('c3y',fmt(c*.03)); set('c3ynet',fmt(c*.03*.855));
  set('c3ytot',fmt(c*.03*.855*3));
  // 6Y
  set('inv6y',fmt(c)); set('c6y1',fmt(c*.04*.855)); set('c6y2',fmt(c*.03*.855)); set('c6y3',fmt(c*.015*.855));
  // MS/ZC
  set('invms',fmt(c)); set('invzc',fmt(c)); set('vzc',fmt(c*1.20));
  // Cert
  set('invcert',fmt(c)); set('ccert',fmt(c*.065)); set('ccertm',fmt(c*.065/12));
  // Longevity
  set('invlong',fmt(c)); set('vlong',fmt(c*Math.pow(1.06,24)));
  calcPAC();
  // PE 2.5x
  set('invpe',fmt(c));
  set('vpe25',fmt(c*2.5)); set('gpe',fmt(c*1.5));
  // PE bar text
  const barEl = document.getElementById('peBarText');
  if(barEl) barEl.textContent = fmt(c)+' → '+fmt(c*2.5);
  const subEl = document.getElementById('peReturnSub');
  if(subEl) subEl.textContent = 'Stima: '+fmt(c)+' → '+fmt(c*2.5)+' in 7 anni · CAGR ~14%';
  // Ref
  set('capRef', fmt(c));
  // Portfolio
  updatePortfolio(c);
  // Lombard sync
  const lp = document.getElementById('lcP');
  if(lp){ lp.value = Math.round(c); document.getElementById('lcPS').value=c; }
  calcLombard();
}

function set(id,v){const el=document.getElementById(id);if(el)el.textContent=v}

function updatePortfolio(c){
  set('pbTot',fmt(c));
  set('pb7y',fmt(c*.35)); set('pb3y',fmt(c*.20)); set('pbce',fmt(c*.15));
  set('pbetf',fmt(c*.15)); set('pblo',fmt(c*.10)); set('pbpe',fmt(c*.05));
  const ced = c*.35*.05 + c*.20*.053 + c*.15*.065;
  set('pbCed',fmt(ced));
  set('pbRend',fmtPct(ced/c*100));
  set('pbProt',fmt(c*.70));
}

// ════════════════════════════════════════════
